# Sensitive config — contains API keys, never commit
.mcp.json
.env
*.env.*
.linkedin_token

# Browser sessions — private login state
_conclave/_browser_profile/

# Backup files generated by Conclave overwrite protection
**/*.bak-*

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/
package-lock.json

# Build artifacts
_build/
_conclave/logs/
squads/*/output/*
squads/*/_build/*

# IDE local settings
.opencode/
.scratch_skills/

# Large caches
.npm-cache/
.nvm/
.puppeteer-cache/

# Visual references (personal — add your own)
ref_visual_style/*
!ref_visual_style/README.md
ref_brand-style/*
!ref_brand-style/README.md

# Validation logs
*.log
